# Neon Postgres connection string (pooled URL is fine for the serverless driver).
# Get this from the Neon dashboard, or `vercel env pull .env` once linked.
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-west-2.aws.neon.tech/flutterby?sslmode=require"

# Port the Fastify API listens on in local development (see api/dev.ts).
PORT=3001
