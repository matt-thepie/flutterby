# Neon Postgres connection string (pooled URL is fine for the serverless driver).
# Get this from the Neon dashboard, or `vercel env pull .env` once linked.
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-west-2.aws.neon.tech/flutterby?sslmode=require"

# Port the Fastify API listens on in local development (see api/dev.ts).
PORT=3001

# --- Auth (optional — only needed for multi-device sign-in/sync) --------------
# A random secret for Better Auth. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# The app's public base URL. Locally this is the Vite origin; in production set
# it to your Vercel URL, e.g. https://flutterby.vercel.app
BETTER_AUTH_URL="http://localhost:5173"

# Google OAuth (free) — https://console.cloud.google.com → Credentials.
# Authorised redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook Login (free) — https://developers.facebook.com → your app.
# Valid OAuth redirect URI: <BETTER_AUTH_URL>/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Apple (NOT free — needs a paid Apple Developer account). Leave blank to skip;
# the Apple button only appears once these are set.
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""
