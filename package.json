{
  "name": "flutterby",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A phone-first butterfly logging app for UK recorders — captures species, count and an OS grid reference in a couple of taps.",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch --env-file=.env server/dev.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env db/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.10.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.23",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
